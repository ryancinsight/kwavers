<?xml version="1.0" encoding="UTF-8"?>
<!--
    JUnit-style XML Template for k-Wave Python Parity Validation Reports

    This template follows JUnit XML format for CI/CD integration.
    Compatible with Jenkins, GitLab CI, GitHub Actions, and other CI systems.

    Schema: junit.xsd (version 4)
    Usage: Generated by validation_reports/generate_report.py
-->
<testsuites name="kwave-python-parity-validation" time="${TOTAL_TIME}" tests="${TOTAL_TESTS}" failures="${TOTAL_FAILURES}" errors="${TOTAL_ERRORS}" skipped="${TOTAL_SKIPPED}">

    <!--
        Test Suite: Component Validation
        Groups validation tests by component (Grid, Source, Signal, Sensor, Solver)
    -->
    <testsuite name="Grid.Validation" time="${GRID_TIME}" tests="${GRID_TESTS}" failures="${GRID_FAILURES}" errors="${GRID_ERRORS}" skipped="${GRID_SKIPPED}">
        ${GRID_TESTCASES}
    </testsuite>

    <testsuite name="Source.Validation" time="${SOURCE_TIME}" tests="${SOURCE_TESTS}" failures="${SOURCE_FAILURES}" errors="${SOURCE_ERRORS}" skipped="${SOURCE_SKIPPED}">
        ${SOURCE_TESTCASES}
    </testsuite>

    <testsuite name="Signal.Validation" time="${SIGNAL_TIME}" tests="${SIGNAL_TESTS}" failures="${SIGNAL_FAILURES}" errors="${SIGNAL_ERRORS}" skipped="${SIGNAL_SKIPPED}">
        ${SIGNAL_TESTCASES}
    </testsuite>

    <testsuite name="Sensor.Validation" time="${SENSOR_TIME}" tests="${SENSOR_TESTS}" failures="${SENSOR_FAILURES}" errors="${SENSOR_ERRORS}" skipped="${SENSOR_SKIPPED}">
        ${SENSOR_TESTCASES}
    </testsuite>

    <testsuite name="Solver.Validation" time="${SOLVER_TIME}" tests="${SOLVER_TESTS}" failures="${SOLVER_FAILURES}" errors="${SOLVER_ERRORS}" skipped="${SOLVER_SKIPPED}">
        ${SOLVER_TESTCASES}
    </testsuite>

    <!--
        Test Case Template (to be repeated for each test):

        <testcase name="${TEST_NAME}" classname="${COMPONENT}.${TEST_TYPE}" time="${EXECUTION_TIME}">
            <properties>
                <property name="k_wave_python_version" value="${K_WAVE_VERSION}"/>
                <property name="pykwavers_version" value="${PYKWAVERS_VERSION}"/>
                <property name="l2_error" value="${L2_ERROR}"/>
                <property name="linf_error" value="${LINF_ERROR}"/>
                <property name="relative_error" value="${RELATIVE_ERROR}"/>
                <property name="tolerance" value="${TOLERANCE}"/>
                <property name="pass_threshold" value="${PASS_THRESHOLD}"/>
                <property name="test_description" value="${TEST_DESCRIPTION}"/>
                <property name="execution_timestamp" value="${TIMESTAMP}"/>
            </properties>
            <system-out>
                <![CDATA[
                Detailed validation output...
                ]]>
            </system-out>
            <failure message="${FAILURE_MESSAGE}" type="${FAILURE_TYPE}">
                <![CDATA[
                Expected: ${EXPECTED_VALUE}
                Actual: ${ACTUAL_VALUE}
                Absolute Error: ${ABSOLUTE_ERROR}
                Relative Error: ${RELATIVE_ERROR}%
                ]]>
            </failure>
        </testcase>
    -->

</testsuites>
