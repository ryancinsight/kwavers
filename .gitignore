# Architecture Audit Document
# This .gitignore file excludes build artifacts and temporary files

# Generated by Cargo
# will have compiled files and executables
debug/
target/
target_opt/
external/

# Regenerable caches, reports, and local environments (not version-controlled)
kwave_cache/
.pytest_cache/
.benchmarks/
.venv-msys/

# Local dev run scripts (hardcoded absolute paths; not portable)
run_*.bat

# Binary executables without extensions
fft_demo
test_octree
bench_plane_wave*

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
# Cargo.lock

# Redundant Cargo.toml variants (SSOT violation - Sprint 118)
Cargo.toml.*

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Python extension modules (built by maturin)
*.pyd

# Binary files
fft_demo
test_octree
*.o
*.so
*.dll
*.exe

# Windows linker import-library artifacts emitted at the repo root during native builds
api-ms-*.def
api-ms-*.exp
api-ms-*.lib

# Oversized clinical-imaging sample volumes (>100 MB; exceeds GitHub upload cap).
# These are fetched into the working tree from public dataset mirrors; the
# data/<dataset>/README.md inside each sample directory documents the source.
data/kits19_sample/case_*.nii.gz
data/cfb_gbm_sample/*.nii.gz
# Core dumps (be specific to avoid excluding src files)
/core
/core.*
*.core

# Backup files
*.bak
*.backup
*~
*.swp
*.swo

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
#.idea/

# Simulation output artifacts
*.csv
*.html
*.log
!requirements.txt

# All txt files except requirements
*.txt
!requirements.txt

# k-Wave example replication output directories
kwave_replication_outputs_*/

# External vendor repos and Julia parity worktrees
/external/

# Build artifacts
*.o
*.so
*.dylib
*.dll
*.exe
fft_demo
test_octree
bench_*

# Redundant documentation (only keep essential docs)
# Allow refactoring docs but block other temporary docs
# *_SUMMARY.md
# *_REVIEW.md
# *_REPORT.md
# *_UPDATE.md
# *_PROGRESS.md
*IMPROVEMENTS*.md
*OPTIMIZATION*.md
PULL_REQUEST.md
CRITICAL_FIXES*.md
CLEANUP*.md
BUG_FIXES*.md
ANALYTICAL_TEST*.md

# Python bytecode and caches (should never be committed)
*.pyc
__pycache__/

# NumPy/binary data outputs
*.npy
*.npz

# Errors
*.err

# Root Python files
/*.py
target_opt/

# Confidential folder (never tracked or uploaded)
leoneuro/
